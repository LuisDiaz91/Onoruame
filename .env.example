# .env.example - PLANTILLA para configuración
# Copia este archivo a .env y edita con tus datos reales

# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=onoruame
DB_USER=postgres
DB_PASSWORD=postgres

# Google Maps - PON TU API KEY AQUÍ (en .env, no aquí)
GOOGLE_MAPS_API_KEY=tu_api_key_aqui

# Origen
ORIGEN_COORDS=19.4283717,-99.1430307
ORIGEN_NOMBRE=TSJCDMX - Niños Héroes 150

# Redis (opcional)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Railway (opcional)
RAILWAY_URL=
