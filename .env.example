"""
Configuración centralizada usando Pydantic Settings.
Lee variables de entorno y archivo .env automáticamente.
"""

from pydantic_settings import BaseSettings, SettingsConfigDict
from typing import List, Optional
import os
from dotenv import load_dotenv

# Cargar explícitamente el archivo .env
load_dotenv()

class Settings(BaseSettings):
    # Google Maps (OBLIGATORIO)
    GOOGLE_MAPS_API_KEY: str

    # Database
    DB_HOST: str = "localhost"
    DB_PORT: int = 5432
    DB_NAME: str = "onoruame"
    DB_USER: str = "postgres"
    DB_PASSWORD: str = "postgres"

    # Origen
    ORIGEN_COORDS: str = "19.4283717,-99.1430307"
    ORIGEN_NOMBRE: str = "TSJCDMX - Niños Héroes 150"

    # Configuración de rutas
    MAX_EDIFICIOS_POR_RUTA: int = 8
    TIMEOUT_API: int = 15

    # Redis
    REDIS_HOST: str = "localhost"
    REDIS_PORT: int = 6379
    REDIS_PASSWORD: Optional[str] = None

    # Railway (opcional)
    RAILWAY_URL: Optional[str] = None

    # Carpetas del sistema
    CARPETAS: List[str] = [
        'mapas_pro', 'rutas_excel', 'rutas_telegram',
        'avances_ruta', 'fotos_entregas', 'fotos_reportes'
    ]

    # Configuración de Pydantic para leer de .env
    model_config = SettingsConfigDict(
        env_file='.env',          # Archivo a leer
        env_file_encoding='utf-8', # Codificación
        extra='ignore'             # Ignorar variables extra
    )

# Instancia global de configuración
settings = Settings()

# Para debugging: verificar que se cargó la API key
print(f"🔑 API Key cargada: {'✓' if settings.GOOGLE_MAPS_API_KEY else '✗'}")
if not settings.GOOGLE_MAPS_API_KEY:
    print("⚠️  ADVERTENCIA: GOOGLE_MAPS_API_KEY no está configurada en .env")
